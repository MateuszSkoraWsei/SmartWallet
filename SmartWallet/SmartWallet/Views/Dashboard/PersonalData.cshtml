@model SmartWallet.Models.ApplicationUser

@{
    ViewData["Title"] = "Mój Profil";
    Layout = "_DashboardLayout";
    
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4 mb-4">
                <div class="position-relative d-inline-block mx-auto mb-3">
                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <img src="@Model.ProfilePictureUrl" class="rounded-circle img-thumbnail shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center shadow-sm mx-auto" style="width: 150px; height: 150px;">
                            <i class="bi bi-person text-secondary" style="font-size: 4rem;"></i>
                        </div>
                    }
                </div>
                <h4 class="fw-bold">@Model.Name @Model.Surname</h4>
                <p class="text-muted small">@Model.Email</p>
                <div class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                    Klient SmartWallet
                </div>
                <hr class="my-4">
                <div class="text-start">
                    <p class="mb-1"><strong>Nr konta:</strong></p>
                    <code class="text-dark bg-light p-2 d-block rounded">@Model.AccountNumber</code>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h5 class="fw-bold mb-4">Informacje osobiste</h5>
                

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            Imię: @Model.Name
                        </div>
                        <div class="col-md-6 mb-3">
                            Nazwisko: @Model.Surname
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            Płeć: @Model.Gender
                        </div>
                        <div class="col-md-6 mb-3">
                            Data urodzenia: @Model.DateOfBirth.ToString("dd:MM:yyyy")
                        </div>
                    </div>

                    <div class="mb-3">
                        Addres: @Model.address
                    </div>

                    

                    <div class="d-flex justify-content-end">
                        <a asp-controller="dashboard" asp-action="editProfile"> Edytuj dane </a>
                    </div>
                <div class="mb-3">
                    <label class="form-label d-block fw-bold">Status weryfikacji</label>
                    @if (Model.EmailConfirmed)
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle-fill me-1"></i> Zweryfikowany
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            <i class="bi bi-x-circle-fill me-1"></i> Niezweryfikowany
                        </span>
                        <div class="mt-2">
                            <small class="text-muted d-block mb-1">Twój adres e-mail nie został jeszcze potwierdzony.</small>
                            <button class="btn btn-outline-primary btn-sm">Wyślij link ponownie</button>
                        </div>
                    }
                </div>
                
            </div>
        </div>
    </div>
</div>